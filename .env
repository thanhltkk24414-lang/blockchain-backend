# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# DATABASE
# ============================================
MONGODB_URI=mongodb://localhost:27017/freelance-platform

# ============================================
# BLOCKCHAIN - RPC
# ============================================
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
CHAIN_ID=11155111

# ============================================
# BLOCKCHAIN - CONTRACT ADDRESSES (SEPOLIA)
# ============================================

# Mock USDC Token
USDC_ADDRESS=0x2293193Eaa5CE5253d5e081046a06dB077f26f8e

# Reputation Store - Quản lý điểm uy tín
REPUTATION_STORE_ADDRESS=0x7A96219812e9363dBdbD43BE14384820E5f9b0DC

# Platform Treasury - Quản lý stake và quỹ
PLATFORM_TREASURY_ADDRESS=0x0110BfF85E484b82205833D3950fC7C61714c0e7

# Job Registry - Quản lý công việc
JOB_REGISTRY_ADDRESS=0xeF5cc7a22D7Ff9e7FA0c5Fe714F088c98758A549

# Arbitrator Panel - Hội đồng trọng tài
ARBITRATOR_PANEL_ADDRESS=0x324e7d8Cfe5aBdb62caa236Bb23626E23BC7EC4F

# Escrow Vault - Ký quỹ và thanh toán
ESCROW_VAULT_ADDRESS=0xf2143d1EA4D5a8716344c2cef862f9ed41244ED5

# ============================================
# INDEXER - Private Key để sync events
# ============================================
# ⚠️ Tạo ví riêng cho indexer, KHÔNG dùng ví chính
INDEXER_PRIVATE_KEY=0xyour_indexer_private_key_here

# ============================================
# IPFS CONFIGURATION
# ============================================
IPFS_GATEWAY_URL=https://ipfs.infura.io:5001
IPFS_API_KEY=YOUR_IPFS_PROJECT_ID
IPFS_API_SECRET=YOUR_IPFS_PROJECT_SECRET

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=9accd6ee7abe9f18dd698de02c2f50a60ef07422b7b3856a72c5b95a9bf60460
JWT_EXPIRES_IN=7d

# ============================================
# CORS - Cho phép frontend truy cập
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
