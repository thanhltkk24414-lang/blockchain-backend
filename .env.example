# =============================================================================
# Backend environment — REQUIRED: copy this file to backend/.env
#   cp .env.example .env   (or copy manually on Windows)
#
# Backend reads ONLY backend/.env (not contracts/.env at repo root).
# Copy SEPOLIA_RPC_URL from contracts/.env into RPC_URL below.
# Contract addresses: from ../deployments/sepolia.json (repo root).
# =============================================================================

# Server
PORT=5000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# MongoDB — pick one option below (required for auth, jobs, event indexer)
#
# Option A — local Docker (recommended on Windows):
#   npm run docker:mongo
#   MONGODB_URI=mongodb://127.0.0.1:27017/freelance-platform
#
# Option B — local MongoDB service (default install):
#   MONGODB_URI=mongodb://127.0.0.1:27017/freelance-platform
#
# Option C — MongoDB Atlas free tier:
#   MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/freelance-platform?retryWrites=true&w=majority
#
MONGODB_URI=mongodb://127.0.0.1:27017/freelance-platform

# Sepolia RPC — Infura, Alchemy, or public endpoint
# Same value as SEPOLIA_RPC_URL in contracts/.env at monorepo root
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# JWT auth (generate a long random string)
JWT_SECRET=your_super_secret_key_change_me
JWT_EXPIRES_IN=7d

# SIWE (Sign-In With Ethereum)
# Domain shown in the wallet sign-in prompt (no protocol)
SIWE_DOMAIN=localhost
# Full app URL used as SIWE URI (include protocol)
APP_URL=http://localhost:3000
# Sepolia chain ID
CHAIN_ID=11155111

# Event indexer — set false for local Postman testing (avoids Infura rate limits)
ENABLE_EVENT_INDEXER=true
# INDEXER_BATCH_SIZE=100
# INDEXER_POLL_CRON=0 */2 * * * *
# INDEXER_RPC_DELAY_MS=500

# Required for POST /api/jobs (JobRegistry.createJob) and indexer/cron on-chain txs.
# Sepolia wallet private key with ETH for gas — no 0x prefix.
INDEXER_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Deployed contract addresses (Sepolia) — from deployments/sepolia.json
# -----------------------------------------------------------------------------
MOCK_USDC_ADDRESS=0x2293193Eaa5CE5253d5e081046a06dB077f26f8e
REPUTATION_STORE_ADDRESS=0x9B0041E95fc236cB296296BE6E4dD6cdFc4eF3Ff
PLATFORM_TREASURY_ADDRESS=0xd752C7C94e6571e9781aB8dAc54c749f33BD09Fe
JOB_REGISTRY_ADDRESS=0xE5425cFE21BAe73d54138Bb290B671bF4c55FBC9
# After JobRegistry redeploy: set previous registry so old MongoDB jobs stay scoped (run scripts/migrate-job-registry-index.js)
# LEGACY_JOB_REGISTRY_ADDRESS=0xPreviousJobRegistryAddress
ARBITRATOR_PANEL_ADDRESS=0x96eCEfBd86dF049994fd411689566B126afcd0EB
ESCROW_VAULT_ADDRESS=0xeE67C7bdC2679aa86b6eA4b7311a74B4c8bf6DD3

# -----------------------------------------------------------------------------
# IPFS — Pinata (used by src/config/ipfs.js)
# Create keys at https://app.pinata.cloud/developers/api-keys
# -----------------------------------------------------------------------------
IPFS_GATEWAY_URL=https://gateway.pinata.cloud

# Option A — JWT (recommended)
PINATA_JWT=your_pinata_jwt

# Option B — API key pair
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret_api_key

# Legacy aliases (still supported)
# IPFS_API_KEY=your_pinata_api_key
# IPFS_API_SECRET=your_pinata_secret_api_key

# Optional: WebSocket RPC for realtime EscrowVault event listener (chain → DB → Socket.io)
# SEPOLIA_WSS_URL=wss://sepolia.infura.io/ws/v3/YOUR_INFURA_PROJECT_ID
#
# Socket.io client notifications use the same HTTP server (path /socket.io).
# Auth: JWT from POST /api/auth/verify. CORS origins: ALLOWED_ORIGINS.
