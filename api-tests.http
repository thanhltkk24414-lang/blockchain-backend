# Fapex API — REST Client (humao.rest-client)
# Install: VS Code/Cursor → Extensions → search "REST Client" (humao.rest-client)
# Usage: open this file → click "Send Request" above each ### block
# Windows: use 127.0.0.1 instead of localhost (avoids IPv6 hangs)

@baseUrl = http://127.0.0.1:5000
@walletAddress = 0xYourWalletAddressHere
@authToken =

# SIWE — http://127.0.0.1:5000/siwe-sign.html (v4, EIP-55) → sign → "Copy JSON cho Postman"
# After git pull: restart backend + hard refresh (Ctrl+Shift+R) if banner v4 missing.
# Multiline SIWE messages break JSON if pasted with literal newlines into variables.
# Recommended: copy verify-body.json.example → verify-body.json, paste copied JSON from siwe-sign page, use request 03b below.
@siweMessage = PASTE_FULL_SIWE_MESSAGE_HERE
@siweSignature = 0xPASTE_SIGNATURE_HERE

### 01 — GET /health (no auth)
GET {{baseUrl}}/health

### 02 — POST /api/auth/nonce (needs MongoDB)
POST {{baseUrl}}/api/auth/nonce
Content-Type: application/json

{
  "walletAddress": "{{walletAddress}}"
}

### 03 — POST /api/auth/verify (env vars — message must be ONE line with \n escapes, or use 03b)
# Postman users: re-import Fapex.postman_collection.json (pre-request script handles multiline env vars).
# REST Client: literal newlines in @siweMessage will break JSON — prefer 03b or escape newlines as \n on one line.
POST {{baseUrl}}/api/auth/verify
Content-Type: application/json

{
  "message": "{{siweMessage}}",
  "signature": "{{siweSignature}}"
}

### 03b — POST /api/auth/verify (recommended — paste JSON from siwe-sign "Copy JSON cho Postman")
# 1. cp verify-body.json.example verify-body.json
# 2. On siwe-sign.html: sign → Copy JSON cho Postman → replace entire verify-body.json contents
# 3. Send this request
POST {{baseUrl}}/api/auth/verify
Content-Type: application/json

< ./verify-body.json

### 04 — GET /api/auth/me (needs JWT from verify → copy token to @authToken)
GET {{baseUrl}}/api/auth/me
Authorization: Bearer {{authToken}}

### 05 — POST /api/ipfs/upload/metadata (needs auth + Pinata in backend .env)
POST {{baseUrl}}/api/ipfs/upload/metadata
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "title": "Smart Contract Audit",
  "description": "Audit Solidity escrow contracts on Sepolia testnet.",
  "category": "development",
  "skills": ["Solidity", "Security"],
  "deliverables": "PDF audit report with findings and remediation plan.",
  "acceptanceCriteria": "All critical and high issues documented with reproducible PoCs.",
  "clientAddress": "{{walletAddress}}",
  "createdAt": "2026-06-23T00:00:00.000Z"
}

### 06 — POST /api/jobs (needs auth + MongoDB + Pinata + RPC)
POST {{baseUrl}}/api/jobs
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "title": "Smart Contract Audit",
  "description": "Audit Solidity escrow contracts on Sepolia testnet for security vulnerabilities.",
  "category": "development",
  "contractValue": 100,
  "duration": 604800,
  "skills": ["Solidity", "Security"],
  "deliverables": "PDF audit report with findings and remediation plan.",
  "acceptanceCriteria": "All critical and high issues documented with reproducible PoCs."
}

### 07 — GET /api/jobs (public list)
GET {{baseUrl}}/api/jobs?page=1&limit=20
